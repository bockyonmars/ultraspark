generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContactMessageStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

enum QuoteRequestStatus {
  NEW
  CONTACTED
  QUOTED
  ACCEPTED
  DECLINED
  ARCHIVED
}

enum BookingRequestStatus {
  NEW
  CONTACTED
  CONFIRMED
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum SupportTicketCategory {
  GENERAL_ENQUIRY
  COMPLAINT
  BOOKING_ISSUE
  PAYMENT_ISSUE
  CLEANING_QUALITY
  STAFF_ISSUE
  RESCHEDULE_REQUEST
  CANCELLATION_REQUEST
  OTHER
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SupportTicketStatus {
  NEW
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
  ARCHIVED
}

enum SupportTicketMessageType {
  INTERNAL_NOTE
  CUSTOMER_REPLY
}

enum EmailLogStatus {
  DRAFT
  SENT
  FAILED
}

enum QuoteDocumentType {
  HOUSE_CLEANING_QUOTE
  HOUSE_CLEANING_ESTIMATE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum CustomerActivityType {
  QUOTE_CREATED
  QUOTE_SENT
  INVOICE_CREATED
  INVOICE_UPLOADED
  INVOICE_SENT
  INVOICE_PAID
  EMAIL_SENT
  EMAIL_FAILED
  SUPPORT_TICKET_CREATED
  BOOKING_UPDATED
  NOTE_ADDED
}

enum AnalyticsEventType {
  CONTACT_SUBMITTED
  QUOTE_SUBMITTED
  BOOKING_SUBMITTED
  SUPPORT_TICKET_SUBMITTED
}

enum AuditAction {
  CONTACT_CREATED
  CONTACT_STATUS_UPDATED
  QUOTE_CREATED
  QUOTE_STATUS_UPDATED
  QUOTE_UPDATED
  QUOTE_SENT
  INVOICE_CREATED
  INVOICE_UPDATED
  INVOICE_SENT
  INVOICE_PAID
  BOOKING_CREATED
  BOOKING_STATUS_UPDATED
  ADMIN_LOGIN
  SUPPORT_TICKET_CREATED
  SUPPORT_TICKET_UPDATED
  SUPPORT_TICKET_STATUS_UPDATED
  SUPPORT_TICKET_ASSIGNED
  SUPPORT_TICKET_MESSAGE_CREATED
}

model AdminUser {
  id                      String                  @id @default(cuid())
  email                   String                  @unique
  firstName               String
  lastName                String
  passwordHash            String
  isActive                Boolean                 @default(true)
  lastLoginAt             DateTime?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  auditLogs               AuditLog[]
  assignedSupportTickets  SupportTicket[]         @relation("AssignedSupportTickets")
  supportTicketMessages   SupportTicketMessage[]
  supportTicketActivities SupportTicketActivity[]
  createdInvoices         Invoice[]               @relation("InvoiceCreatedBy")
  sentEmailLogs           EmailLog[]              @relation("EmailLogSentBy")
  customerActivities      CustomerActivity[]      @relation("CustomerActivityCreatedBy")
}

model Customer {
  id              String             @id @default(cuid())
  firstName       String?
  lastName        String?
  email           String?            @unique
  phone           String?            @unique
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  contactMessages ContactMessage[]
  quoteRequests   QuoteRequest[]
  quotes          Quote[]
  bookingRequests BookingRequest[]
  supportTickets  SupportTicket[]
  invoices        Invoice[]
  emailLogs       EmailLog[]
  activities      CustomerActivity[]
}

model Service {
  id              String           @id @default(cuid())
  name            String           @unique
  slug            String           @unique
  description     String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  quoteRequests   QuoteRequest[]
  bookingRequests BookingRequest[]
}

model ContactMessage {
  id         String               @id @default(cuid())
  customerId String
  subject    String?
  message    String
  source     String?
  status     ContactMessageStatus @default(NEW)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  customer   Customer             @relation(fields: [customerId], references: [id])
  emailLogs  EmailLog[]
}

model QuoteRequest {
  id             String             @id @default(cuid())
  customerId     String
  serviceId      String
  postcode       String?
  propertyType   String?
  bedrooms       Int?
  bathrooms      Int?
  preferredDate  DateTime?
  details        String
  status         QuoteRequestStatus @default(NEW)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  customer       Customer           @relation(fields: [customerId], references: [id])
  service        Service            @relation(fields: [serviceId], references: [id])
  emailLogs      EmailLog[]
  supportTickets SupportTicket[]
  createdQuote   Quote?             @relation("QuoteRequestCreatedQuote")
}

model Quote {
  id                  String            @id @default(cuid())
  customerId          String?
  quoteRequestId      String?           @unique
  quoteNumber         String            @unique
  documentType        QuoteDocumentType @default(HOUSE_CLEANING_QUOTE)
  customerName        String
  customerEmail       String
  customerPhone       String?
  customerAddress     String?
  serviceAddress      String?
  issueDate           DateTime
  expiryDate          DateTime?
  preparedBy          String?
  status              QuoteStatus       @default(DRAFT)
  paymentTerms        String?
  specialInstructions String?
  included            String?
  excluded            String?
  notes               String?
  showSignature       Boolean           @default(true)
  subtotal            Decimal           @default(0) @db.Decimal(10, 2)
  discount            Decimal           @default(0) @db.Decimal(10, 2)
  tax                 Decimal           @default(0) @db.Decimal(10, 2)
  total               Decimal           @default(0) @db.Decimal(10, 2)
  sentAt              DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  customer            Customer?         @relation(fields: [customerId], references: [id])
  sourceQuoteRequest  QuoteRequest?     @relation("QuoteRequestCreatedQuote", fields: [quoteRequestId], references: [id])
  lineItems           QuoteLineItem[]
  emailLogs           EmailLog[]
  invoices            Invoice[]

  @@index([status])
  @@index([documentType])
  @@index([customerEmail])
  @@index([createdAt])
}

model QuoteLineItem {
  id          String   @id @default(cuid())
  quoteId     String
  serviceName String
  description String?
  rate        Decimal  @default(0) @db.Decimal(10, 2)
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  total       Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model BookingRequest {
  id             String               @id @default(cuid())
  customerId     String
  serviceId      String
  postcode       String?
  address        String?
  propertyType   String?
  bedrooms       Int?
  bathrooms      Int?
  preferredDate  DateTime?
  preferredTime  String?
  details        String?
  status         BookingRequestStatus @default(NEW)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  customer       Customer             @relation(fields: [customerId], references: [id])
  service        Service              @relation(fields: [serviceId], references: [id])
  emailLogs      EmailLog[]
  supportTickets SupportTicket[]
  invoices       Invoice[]
}

model SupportTicket {
  id                String                  @id @default(cuid())
  ticketNumber      String                  @unique
  customerId        String?
  customerName      String
  customerEmail     String?
  customerPhone     String?
  category          SupportTicketCategory   @default(GENERAL_ENQUIRY)
  priority          SupportTicketPriority   @default(MEDIUM)
  status            SupportTicketStatus     @default(NEW)
  subject           String
  description       String
  source            String?
  internalNotes     String?
  assignedToAdminId String?
  relatedBookingId  String?
  relatedQuoteId    String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  closedAt          DateTime?
  customer          Customer?               @relation(fields: [customerId], references: [id])
  assignedToAdmin   AdminUser?              @relation("AssignedSupportTickets", fields: [assignedToAdminId], references: [id])
  relatedBooking    BookingRequest?         @relation(fields: [relatedBookingId], references: [id])
  relatedQuote      QuoteRequest?           @relation(fields: [relatedQuoteId], references: [id])
  messages          SupportTicketMessage[]
  activities        SupportTicketActivity[]
  emailLogs         EmailLog[]
  invoices          Invoice[]

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([customerEmail])
  @@index([createdAt])
}

model SupportTicketMessage {
  id            String                   @id @default(cuid())
  ticketId      String
  type          SupportTicketMessageType
  message       String
  authorAdminId String?
  createdAt     DateTime                 @default(now())
  ticket        SupportTicket            @relation(fields: [ticketId], references: [id])
  authorAdmin   AdminUser?               @relation(fields: [authorAdminId], references: [id])
}

model SupportTicketActivity {
  id          String        @id @default(cuid())
  ticketId    String
  action      String
  description String
  adminUserId String?
  metadata    Json?
  createdAt   DateTime      @default(now())
  ticket      SupportTicket @relation(fields: [ticketId], references: [id])
  adminUser   AdminUser?    @relation(fields: [adminUserId], references: [id])
}

model EmailLog {
  id                String            @id @default(cuid())
  type              String
  recipient         String
  cc                String?
  bcc               String?
  subject           String
  body              String?
  status            EmailLogStatus
  provider          String?
  providerMessageId String?
  errorMessage      String?
  customerId        String?
  contactMessageId  String?
  quoteRequestId    String?
  quoteId           String?
  invoiceId         String?
  bookingRequestId  String?
  supportTicketId   String?
  sentByAdminId     String?
  sentAt            DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  customer          Customer?         @relation(fields: [customerId], references: [id])
  contactMessage    ContactMessage?   @relation(fields: [contactMessageId], references: [id])
  quoteRequest      QuoteRequest?     @relation(fields: [quoteRequestId], references: [id])
  quote             Quote?            @relation(fields: [quoteId], references: [id])
  invoice           Invoice?          @relation(fields: [invoiceId], references: [id])
  bookingRequest    BookingRequest?   @relation(fields: [bookingRequestId], references: [id])
  supportTicket     SupportTicket?    @relation(fields: [supportTicketId], references: [id])
  sentByAdmin       AdminUser?        @relation("EmailLogSentBy", fields: [sentByAdminId], references: [id])
  attachments       EmailAttachment[]

  @@index([customerId])
  @@index([invoiceId])
  @@index([bookingRequestId])
  @@index([quoteId])
  @@index([supportTicketId])
  @@index([createdAt])
}

model EmailAttachment {
  id         String   @id @default(cuid())
  emailLogId String
  fileName   String
  fileUrl    String
  fileType   String?
  fileSize   Int?
  createdAt  DateTime @default(now())
  emailLog   EmailLog @relation(fields: [emailLogId], references: [id], onDelete: Cascade)

  @@index([emailLogId])
}

model Invoice {
  id              String          @id @default(cuid())
  customerId      String?
  bookingId       String?
  quoteId         String?
  supportTicketId String?
  invoiceNumber   String          @unique
  invoiceDate     DateTime
  dueDate         DateTime?
  amount          Decimal         @db.Decimal(10, 2)
  currency        String          @default("GBP")
  status          InvoiceStatus   @default(DRAFT)
  paymentLink     String?
  pdfUrl          String?
  pdfStorageKey   String?
  pdfFileName     String?
  pdfFileSize     Int?
  notes           String?
  paidAt          DateTime?
  paymentMethod   String?
  paymentNotes    String?
  createdById     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  customer        Customer?       @relation(fields: [customerId], references: [id])
  booking         BookingRequest? @relation(fields: [bookingId], references: [id])
  quote           Quote?          @relation(fields: [quoteId], references: [id])
  supportTicket   SupportTicket?  @relation(fields: [supportTicketId], references: [id])
  createdBy       AdminUser?      @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  emailLogs       EmailLog[]

  @@index([customerId])
  @@index([bookingId])
  @@index([quoteId])
  @@index([supportTicketId])
  @@index([status])
  @@index([createdAt])
  @@index([dueDate])
}

model CustomerActivity {
  id                String               @id @default(cuid())
  customerId        String?
  type              CustomerActivityType
  title             String
  description       String?
  relatedEntityType String?
  relatedEntityId   String?
  createdById       String?
  createdAt         DateTime             @default(now())
  customer          Customer?            @relation(fields: [customerId], references: [id])
  createdBy         AdminUser?           @relation("CustomerActivityCreatedBy", fields: [createdById], references: [id])

  @@index([customerId])
  @@index([type])
  @@index([relatedEntityType, relatedEntityId])
  @@index([createdAt])
}

model AnalyticsEvent {
  id         String             @id @default(cuid())
  type       AnalyticsEventType
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime           @default(now())
}

model AuditLog {
  id          String      @id @default(cuid())
  adminUserId String?
  action      AuditAction
  entityType  String
  entityId    String
  description String
  metadata    Json?
  createdAt   DateTime    @default(now())
  adminUser   AdminUser?  @relation(fields: [adminUserId], references: [id])
}
